# Excel Query Agent 环境配置
# 复制此文件为 .env 并填写您的 API Key

# API Key - 必填
# 在阿里云百炼平台获取: https://bailian.console.aliyun.com/
ANTHROPIC_AUTH_TOKEN=your_api_key_here

# API Base URL - 使用阿里云百炼的 Anthropic 兼容端点
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# 模型名称 - 根据您的配置选择
ANTHROPIC_MODEL=glm-5

# 服务端口
PORT=3001